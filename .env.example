# ── Firebase ───────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIRESTORE_DATABASE_ID=             # leave blank for the project's (default) database, or set to a named DB e.g. sonder-db1

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NVIDIA NIM ─────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-...

# ── Pinecone ───────────────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=sonder-index

# ── Embeddings (Ali's decision) ───────────────────────────────────────────────
EMBED_MODEL_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small   # 1536 dims, $0.02/1M tokens
EMBED_DIMENSIONS=1536                # must match chosen model

# ── AI Model Selection (Ali's decision) ───────────────────────────────────────
# Tier → primary provider. The engine falls back to the other provider on
# failure; each client uses its own provider-specific model name below so a
# fallback never sends an Anthropic model id to OpenAI or vice-versa.
SMALL_MODEL_PROVIDER=anthropic
LARGE_MODEL_PROVIDER=anthropic

# Per-provider model ids — used by the corresponding client regardless of
# whether it's the primary or the fallback. Leave blank to take the
# hardcoded default in shared/config.py.
ANTHROPIC_SMALL_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_LARGE_MODEL=claude-sonnet-4-6
OPENAI_SMALL_MODEL=gpt-4o-mini
OPENAI_LARGE_MODEL=gpt-4o

# Legacy single-name vars — kept so existing deployments don't break. New
# code reads the per-provider names above. If set, these only apply to the
# matching provider (e.g. SMALL_MODEL_NAME is used by Anthropic only when
# SMALL_MODEL_PROVIDER=anthropic AND ANTHROPIC_SMALL_MODEL is unset).
# SMALL_MODEL_NAME=
# LARGE_MODEL_NAME=

# ── Validator Model Selection (Mushahid's decision) ───────────────────────────
# Cross-provider critique principle: validators must be a different provider
# family than the generator they grade. Avoids same-family blind spots.

# Small Validator: structural / rule-shaped checks on Large LLM output
SMALL_VALIDATOR_PROVIDER=nvidia
SMALL_VALIDATOR_MODEL_NAME=nvidia/llama-3.1-nemotron-nano-8b-v1

# Large Validator: semantic critic on full itineraries (persona-fit, plausibility)
LARGE_VALIDATOR_PROVIDER=openai
LARGE_VALIDATOR_MODEL_NAME=gpt-5-mini

# ── AWS (required if any MODEL_PROVIDER is set to "bedrock", or for ECS deploy) ─
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=            # leave blank on ECS — IAM task role handles auth
AWS_SECRET_ACCESS_KEY=        # leave blank on ECS — IAM task role handles auth

# Bedrock model IDs (only set the tiers you route to Bedrock)
BEDROCK_SMALL_MODEL_ID=
BEDROCK_LARGE_MODEL_ID=
BEDROCK_SMALL_VALIDATOR_MODEL_ID=   # Mushahid: set if SMALL_VALIDATOR_PROVIDER=bedrock
BEDROCK_LARGE_VALIDATOR_MODEL_ID=   # Mushahid: set if LARGE_VALIDATOR_PROVIDER=bedrock
BEDROCK_EMBED_MODEL_ID=             # Ali: set if EMBED_MODEL_PROVIDER=bedrock

# ── Redis (ElastiCache in production — needed for multi-container WebSocket state) ─
REDIS_URL=                    # e.g. redis://your-cluster.cache.amazonaws.com:6379
                              # leave blank locally — ConnectionManager uses in-memory fallback

# ── Presence ───────────────────────────────────────────────────────────────────
PRESENCE_TTL_SECONDS=90       # user marked offline if no heartbeat within this window

# ── App ────────────────────────────────────────────────────────────────────────
LOCAL_MODE=true
LOG_LEVEL=INFO
MAX_REFINEMENT_ATTEMPTS=3
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
PLAN_TRIP_RATE_LIMIT=5/hour

# ── Currency conversion ────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=           # exchangerate-api.com key — optional; falls back to static rates

# ── Email (transactional — itinerary delivery) ─────────────────────────────────
EMAIL_PROVIDER=resend            # resend | sendgrid | ses
EMAIL_API_KEY=                   # API key for chosen provider
EMAIL_FROM=itinerary@sonder.app  # verified sender address

# ── Web Push (VAPID — closed-browser push notifications) ─────────────────────
# Generate one keypair per environment (dev/prod). Run:
#     python -m scripts.generate_vapid_keys
# and paste both halves below. Leave blank to disable web push (banner +
# Notification-API fallback still work).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@sonder.app

# ── Ranking ───────────────────────────────────────────────────────────────────
# Picks which set of policy modules shreyas/ranking/policies/* the engine
# loads. V1 ships uniform-weight priors. Future versions can co-exist and
# this flag flips between them for A/B testing without code changes.
RANKING_POLICY_VERSION=v1

# ── Monitoring ─────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
POSTHOG_API_KEY=phc_...
# US cloud (default) | EU: https://eu.i.posthog.com | self-host: your URL
POSTHOG_HOST=https://us.i.posthog.com
# Release tracking: Render exposes RENDER_GIT_COMMIT automatically. Locally,
# leave unset or set GIT_COMMIT_SHA manually for testing release grouping.

# ── Frontend (Vite — prefix with VITE_) ───────────────────────────────────────
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=...
VITE_FIREBASE_APP_ID=...
VITE_API_BASE_URL=http://localhost:8000

# Frontend Sentry (leave blank to disable; init is a no-op without DSN)
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=             # production | development; auto-derived from PROD if unset
VITE_SENTRY_RELEASE=         # commit SHA from CI; optional
