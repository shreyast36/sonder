# ── Firebase ───────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Generative AI ───────────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...

# ── Groq ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Mistral ────────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=...

# ── Pinecone ───────────────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=sonder-index

# ── Embeddings (Shreyas's decision) ───────────────────────────────────────────
EMBED_MODEL_PROVIDER=         # openai | bedrock
EMBED_MODEL=                  # model name / ID within that provider
EMBED_DIMENSIONS=1536         # must match your chosen model

# ── AI Model Selection (Ali's decision) ───────────────────────────────────────
# Small tier: fast + cheap tasks (chat topics, labels, quick edits)
SMALL_MODEL_PROVIDER=         # openai | groq | mistral
SMALL_MODEL_NAME=             # model name within that provider

# Large tier: complex tasks (itinerary generation, RAG, conflict resolution)
LARGE_MODEL_PROVIDER=         # openai | anthropic | google
LARGE_MODEL_NAME=             # model name within that provider

# Validator tier: critic checks (feasibility, constraint scoring)
VALIDATOR_MODEL_PROVIDER=     # openai | anthropic
VALIDATOR_MODEL_NAME=         # model name within that provider

# ── AWS (required if any MODEL_PROVIDER is set to "bedrock", or for ECS deploy) ─
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=            # leave blank on ECS — IAM task role handles auth
AWS_SECRET_ACCESS_KEY=        # leave blank on ECS — IAM task role handles auth

# Bedrock model IDs — Ali decides (only set the tiers you route to Bedrock)
BEDROCK_SMALL_MODEL_ID=
BEDROCK_LARGE_MODEL_ID=
BEDROCK_VALIDATOR_MODEL_ID=
BEDROCK_EMBED_MODEL_ID=       # Shreyas: set if EMBED_MODEL_PROVIDER=bedrock

# ── Redis (ElastiCache in production — needed for multi-container WebSocket state) ─
REDIS_URL=                    # e.g. redis://your-cluster.cache.amazonaws.com:6379
                              # leave blank locally — ConnectionManager uses in-memory fallback

# ── App ────────────────────────────────────────────────────────────────────────
LOCAL_MODE=true
LOG_LEVEL=INFO
MAX_REFINEMENT_ATTEMPTS=3

# ── Monitoring ─────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
POSTHOG_API_KEY=phc_...

# ── Frontend (Vite — prefix with VITE_) ───────────────────────────────────────
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=...
VITE_FIREBASE_APP_ID=...
VITE_API_BASE_URL=http://localhost:8000
